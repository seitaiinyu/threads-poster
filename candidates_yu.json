[
 {
  "id": "17927449032337346",
  "text": "足の指が\n これだけ動けば\n 坐骨神経痛は改善します",
  "ts": "2026-05-27T09:00:15+0000",
  "views": 16960
 },
 {
  "id": "17940897984231768",
  "text": "坐骨神経痛、実は「痩せすぎ」も\n 症状が長引く原因になります。",
  "ts": "2026-05-14T21:40:14+0000",
  "views": 14745
 },
 {
  "id": "18079641887531066",
  "text": "坐骨神経痛でも「これ」が出たら、\n 整体ではなく病院へ。",
  "ts": "2026-05-13T22:31:11+0000",
  "views": 14004
 },
 {
  "id": "18171601801418988",
  "text": "坐骨神経痛は\n 右と左で\n 原因が違います",
  "ts": "2026-05-27T11:16:11+0000",
  "views": 13981
 },
 {
  "id": "18314176714273922",
  "text": "梨状筋をほぐすのは\n 実は危険です\n やめてください",
  "ts": "2026-05-15T14:45:37+0000",
  "views": 12433
 },
 {
  "id": "18176105737403675",
  "text": "ほぼ100%効果があるのに\n 誰もやっていない\n 坐骨神経痛の治し方",
  "ts": "2026-05-14T23:31:10+0000",
  "views": 10743
 },
 {
  "id": "18150939970475103",
  "text": "坐骨神経痛の人に\n 絶対にやってほしい\n 股関節のほぐし方",
  "ts": "2026-05-15T21:41:07+0000",
  "views": 10431
 },
 {
  "id": "17966430419920262",
  "text": "坐骨神経痛の人が\n絶対に乗ってはいけない\n乗り物はこれ。",
  "ts": "2026-05-31T11:22:17+0000",
  "views": 10019
 },
 {
  "id": "18128836186721546",
  "text": "女性に坐骨神経痛が多い理由\n知っていましたか？",
  "ts": "2026-06-02T23:13:12+0000",
  "views": 9503
 },
 {
  "id": "18106618177980382",
  "text": "整形外科で「異常なし」と言われた\n 坐骨神経痛の正体はコレです。",
  "ts": "2026-06-06T22:04:12+0000",
  "views": 9348
 },
 {
  "id": "18086971586613808",
  "text": "坐骨神経痛の人、\nこの寝方をしてたら\n悪化するからやめて！",
  "ts": "2026-05-12T09:47:10+0000",
  "views": 8953
 },
 {
  "id": "18072436133672319",
  "text": "【越谷市】\n 61歳の女性が\n 3ヶ月で坐骨神経痛が改善しました\n やめたこと2つ",
  "ts": "2026-05-18T11:01:11+0000",
  "views": 8462
 },
 {
  "id": "18095235922908468",
  "text": "坐骨神経痛は\n 右と左で\n 原因が違います",
  "ts": "2026-05-15T21:49:13+0000",
  "views": 7953
 },
 {
  "id": "18109115768303302",
  "text": "坐骨神経痛、\n 電気とマッサージだけじゃ治らないよ〜",
  "ts": "2026-05-20T22:31:06+0000",
  "views": 7695
 },
 {
  "id": "18069968933656205",
  "text": "坐骨神経痛の人が\n 毎日やってはいけない\n たった1つのこと",
  "ts": "2026-05-15T11:16:11+0000",
  "views": 7661
 },
 {
  "id": "18122950642645398",
  "text": "坐骨神経痛の人が\n気づかずにやっている\n骨盤を歪める習慣はこれだ",
  "ts": "2026-06-03T11:53:16+0000",
  "views": 7306
 },
 {
  "id": "18082177370556801",
  "text": "坐骨神経痛の人が\n 毎日やってほしい\n たった1つのこと",
  "ts": "2026-06-02T09:00:12+0000",
  "views": 7012
 },
 {
  "id": "18323031754267254",
  "text": "女性に坐骨神経痛が多い理由\n 知っていましたか？",
  "ts": "2026-05-15T22:53:10+0000",
  "views": 6880
 },
 {
  "id": "18066748676702723",
  "text": "坐骨神経痛で\n絶対やってはいけない寝方があって、、、",
  "ts": "2026-05-31T23:21:14+0000",
  "views": 6779
 },
 {
  "id": "17991770546987829",
  "text": "坐骨神経痛の人に\n絶対にやってほしい\n股関節のほぐし方がこれ。",
  "ts": "2026-06-02T22:03:07+0000",
  "views": 6648
 },
 {
  "id": "18053634830751069",
  "text": "坐骨神経痛が治らない人、\n内ももを伸ばしてます？",
  "ts": "2026-05-12T12:00:10+0000",
  "views": 6572
 },
 {
  "id": "18070681475673554",
  "text": "坐骨神経痛、\n 接骨院に3年通い続けても\n この2つは変わりません、、、",
  "ts": "2026-05-30T13:00:12+0000",
  "views": 6518
 },
 {
  "id": "18023500499830112",
  "text": "9割のお尻の痛みは、\nくるぶしをほぐすと消えます。\nどうやるかというと、、、",
  "ts": "2026-05-13T21:49:11+0000",
  "views": 6405
 },
 {
  "id": "18117179998690088",
  "text": "坐骨神経痛、\n 靴の踵をつぶして履くと\n 全身に3つの歪みが連鎖します、、、",
  "ts": "2026-05-30T14:30:09+0000",
  "views": 6302
 },
 {
  "id": "18438927673191424",
  "text": "坐骨神経痛の人が\n絶対に乗ってはいけない\n乗り物があるんです。",
  "ts": "2026-05-27T23:23:08+0000",
  "views": 6262
 },
 {
  "id": "18360784348234083",
  "text": "坐骨神経痛を\n1日で治した話をしましょう。",
  "ts": "2026-05-16T11:11:08+0000",
  "views": 6098
 },
 {
  "id": "18077561621653529",
  "text": "坐骨神経痛、\n こんな症状が出たら\n すぐ病院に行ってください。",
  "ts": "2026-06-07T11:25:08+0000",
  "views": 5830
 },
 {
  "id": "17890323591520235",
  "text": "坐骨神経痛、\n寝ている間に悪化させる\nこの2つの寝方が骨盤を歪め続けます、、、",
  "ts": "2026-05-29T22:53:12+0000",
  "views": 5708
 },
 {
  "id": "18043268408574784",
  "text": "ナイショにしていましたが\n坐骨神経痛が3週間でラクにになる方法がこれ。",
  "ts": "2026-05-22T11:25:14+0000",
  "views": 5559
 },
 {
  "id": "17897116902308108",
  "text": "坐骨神経痛、\n片側に体重かけて立つクセ、\nそれが回復を遅らせます。",
  "ts": "2026-05-18T09:27:12+0000",
  "views": 5531
 }
]