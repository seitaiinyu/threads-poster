[
 {
  "id": "17965401252118060",
  "text": "ダイエット中に体重が減らない人の家には\n 必ずこれがあります。",
  "ts": "2026-05-23T21:42:53+0000",
  "views": 65
 },
 {
  "id": "17919677373161998",
  "text": "【悲報】\n 家に食べ物を\n ストックしてる人は痩せません",
  "ts": "2026-06-03T09:23:53+0000",
  "views": 48
 },
 {
  "id": "18082546496633517",
  "text": "痩せたいと言いながら太り続ける人には、\n 3つの共通点があります。",
  "ts": "2026-05-14T13:24:01+0000",
  "views": 46
 },
 {
  "id": "17961984494936699",
  "text": "ダイエット中に\n外食をしていた人が、\n3ヶ月で7kg痩せた方法。",
  "ts": "2026-05-15T21:42:56+0000",
  "views": 38
 },
 {
  "id": "18595007899047380",
  "text": "夜22時〜深夜2時に寝ていると、\n 寝ている間に勝手に脂肪が燃えます。",
  "ts": "2026-06-01T11:51:55+0000",
  "views": 35
 },
 {
  "id": "18129513421608807",
  "text": "血糖値スパイクを防ぐ食べ方5選",
  "ts": "2026-05-27T09:52:53+0000",
  "views": 35
 },
 {
  "id": "18117197989692221",
  "text": "1週間で3kg落とした人と\n3ヶ月で3kg落とした人の末路",
  "ts": "2026-06-02T12:12:57+0000",
  "views": 33
 },
 {
  "id": "18016241897689903",
  "text": "食事中に水を飲みすぎると\n 消化が悪くなります。",
  "ts": "2026-05-19T11:52:13+0000",
  "views": 33
 },
 {
  "id": "18069294293355686",
  "text": "ダイエット中にお酒を飲んでいる人の\n約7割が翌日の対処法を知らなかった",
  "ts": "2026-05-26T11:51:57+0000",
  "views": 32
 },
 {
  "id": "18195662689368658",
  "text": "痩せている人と太っている人の\n 意外な違い3選",
  "ts": "2026-06-07T13:43:54+0000",
  "views": 31
 },
 {
  "id": "18562642987064770",
  "text": "8週間で体脂肪が3.5%減った\n 食事法があります。",
  "ts": "2026-05-24T09:11:53+0000",
  "views": 31
 },
 {
  "id": "17866353642567741",
  "text": "実は太る原因になっている\n 飲み物5選",
  "ts": "2026-06-08T11:35:01+0000",
  "views": 30
 },
 {
  "id": "18338577088218921",
  "text": "40代からでも体脂肪を落とせる理由11選",
  "ts": "2026-05-27T11:42:58+0000",
  "views": 30
 },
 {
  "id": "18147249445450287",
  "text": "【夏までに変わる】\n 体脂肪を落とす\n 正しい順番5ステップ",
  "ts": "2026-06-07T09:52:52+0000",
  "views": 29
 },
 {
  "id": "17975434797046474",
  "text": "食欲を自然に抑える方法7選",
  "ts": "2026-06-04T13:04:54+0000",
  "views": 29
 },
 {
  "id": "18097715692939019",
  "text": "「今月中に5kg落とす！」\r\nリバウンド確定です。",
  "ts": "2026-06-02T09:52:54+0000",
  "views": 29
 },
 {
  "id": "17866591200684465",
  "text": "7月までに5キロ痩せる方法\n\n・3食バランスよく食べる\n・水1日2リットル飲む\n・トイレに座る回数10回以上\n・夕食は寝る3時間前には終わらせる\n・毎日、湯船につかる\n・7時間睡眠を死守",
  "ts": "2026-05-26T13:04:53+0000",
  "views": 29
 },
 {
  "id": "18038714879598171",
  "text": "越谷の整体院で\n 3ヶ月・カロリー計算なしで13kg痩せた人がいます。",
  "ts": "2026-05-14T11:14:56+0000",
  "views": 29
 },
 {
  "id": "18014684873892473",
  "text": "タンパク質が足りていない人に\n 出るサイン5選",
  "ts": "2026-06-08T09:43:53+0000",
  "views": 28
 },
 {
  "id": "18119432977670426",
  "text": "ダイエット中に\n飲んでいい飲み物7選",
  "ts": "2026-06-05T13:23:52+0000",
  "views": 28
 },
 {
  "id": "18068991077697817",
  "text": "液体カロリーで太っている人の飲み物5選",
  "ts": "2026-06-04T11:42:59+0000",
  "views": 28
 },
 {
  "id": "17976423618014603",
  "text": "ダイエット中の外食で選ぶべきメニュー7選",
  "ts": "2026-05-27T13:04:59+0000",
  "views": 28
 },
 {
  "id": "17916839292367003",
  "text": "ダイエット中に「これは食べてはダメ」と\n 我慢するのは逆効果です。",
  "ts": "2026-05-24T13:04:56+0000",
  "views": 28
 },
 {
  "id": "18108411067949148",
  "text": "痩せたい人の9割が見落とす、\n \"水を飲まないこと\"が\n 代謝を下げている事実。",
  "ts": "2026-06-09T11:51:56+0000",
  "views": 27
 },
 {
  "id": "18175394440410022",
  "text": "30代以降に体脂肪が増える本当の理由3選",
  "ts": "2026-06-04T11:51:56+0000",
  "views": 27
 },
 {
  "id": "18137964979541526",
  "text": "むくみの正体は「脂肪」ではありません。\n だから方法を間違えると解消できません。",
  "ts": "2026-05-31T13:43:56+0000",
  "views": 27
 },
 {
  "id": "18138446731530615",
  "text": "あのー。ちょっといいですか？",
  "ts": "2026-05-22T14:43:53+0000",
  "views": 27
 },
 {
  "id": "18185616748376333",
  "text": "糖質を完全にカットすると\n 逆に脂肪が燃えにくくなります。",
  "ts": "2026-05-19T13:33:01+0000",
  "views": 27
 },
 {
  "id": "18121604008654611",
  "text": "夕食が21時以降になっていると\n 確実に太ります、、、",
  "ts": "2026-05-19T11:42:57+0000",
  "views": 27
 },
 {
  "id": "18101799089082201",
  "text": "水を飲まないだけで\n代謝が落ちる理由、、、",
  "ts": "2026-05-13T11:23:56+0000",
  "views": 27
 }
]